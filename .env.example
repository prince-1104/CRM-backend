# --- How URLs fit together ---
# The landing (storefront) and admin apps call this API. You do not set the storefront URL here
# for "connection": on Vercel, set NEXT_PUBLIC_API_URL on the frontend project to this API's URL.
# If the browser calls the API directly, list the storefront origin below.
#
# Comma-separated browser origins allowed to call the API directly (e.g. your Vercel storefront URL).
# Leave empty to disable CORS middleware (Next.js server-side proxy does not need it).
# CORS_ORIGINS=https://your-storefront.vercel.app,https://www.yourdomain.com

# Local dev (default):
DATABASE_URL=sqlite:///./star_uniform.db
# Neon Postgres — Project Dashboard → Connection Details → SQLAlchemy URL.
# Append sslmode=require if not already in the URI, e.g.:
# DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require
# Optional: recycle pooled connections before Neon closes idle TLS (default 280)
# DB_POOL_RECYCLE_SECONDS=280
JWT_SECRET_KEY=your_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
# One-time first admin: long random string. Never commit the real value.
ADMIN_BOOTSTRAP_SECRET=generate_a_long_random_string
# URL of the Next.js admin app only (first-admin setup links in email). Not the public landing site.
ADMIN_APP_BASE_URL=http://localhost:3001
# Resend (https://resend.com) — send setup email for first admin only
RESEND_API_KEY=
# Testing: onboarding@resend.dev — recipient often must be your Resend account email (403 otherwise).
# Production: verify your domain in Resend, then use e.g. noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional
# RESEND_REPLY_TO=
# Setup link lifetime (minutes)
# ADMIN_SETUP_TOKEN_MINUTES=60
# Comma-separated names for "Called by" dropdown in admin leads UI
TEAM_MEMBERS=Sales Team,Operations
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GEMINI_API_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional custom public domain (recommended). If empty, backend uses https://pub-<account-id>.r2.dev
R2_PUBLIC_BASE_URL=
# Upload pipeline: source image is converted to optimized WebP before storing in R2.
# Max width/height for uploaded catalog images (longest side).
CATALOG_IMAGE_MAX_EDGE=1600
# WebP quality 1-100 (higher = larger files).
CATALOG_IMAGE_WEBP_QUALITY=80
# Optional: true for lossless WebP (larger files), false for lossy (recommended).
CATALOG_IMAGE_WEBP_LOSSLESS=false
