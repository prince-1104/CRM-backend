# FastAPI base URL (no trailing slash). Local: http://127.0.0.1:8000 — production: your Railway/API URL.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: Maps Data page loads the Google Maps JS API in the browser (restrict key by HTTP referrer to your admin Vercel domain).
NEXT_PUBLIC_GOOGLE_MAPS_JS_API_KEY=
